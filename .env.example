# ── Discord ────────────────────────────────────────────────────────────────────
# Токен бота: https://discord.com/developers/applications
DISCORD_TOKEN=ваш_токен_бота_здесь

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Имя БД, пользователь и пароль для контейнера db
POSTGRES_DB=elixbot
POSTGRES_USER=elixbot
POSTGRES_PASSWORD=сильный_пароль_здесь

# Хост и порт (внутри Docker-сети — имя сервиса "db")
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Яндекс Музыка ──────────────────────────────────────────────────────────────
# Токен Яндекс Музыки для воспроизведения треков с music.yandex.ru
# Как получить: https://github.com/MarshalX/yandex-music-api/discussions/513
YANDEX_MUSIC_TOKEN=ваш_токен_яндекс_музыки
