# ── Discord ────────────────────────────────────────────────────────────────────
# Токен бота: https://discord.com/developers/applications
DISCORD_TOKEN=ваш_токен_бота_здесь

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=elixbot
POSTGRES_USER=elixbot
POSTGRES_PASSWORD=сильный_пароль_здесь
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Go DB-сервис ───────────────────────────────────────────────────────────────
# Адрес Go-микросервиса (внутри Docker-сети — имя сервиса)
DB_SERVICE_URL=http://db-service:8080
DB_SERVICE_PORT=8080

# ── Резервные копии ────────────────────────────────────────────────────────────
# ID Discord-канала, куда отправлять бэкапы
BACKUP_CHANNEL_ID=ID_канала_для_бэкапов

# Cron-расписание бэкапов (по умолчанию: каждый день в 03:00)
# Формат: "минуты часы день месяц день_недели"
BACKUP_CRON=0 3 * * *

# ── Яндекс Музыка ──────────────────────────────────────────────────────────────
# Как получить токен: https://github.com/MarshalX/yandex-music-api/discussions/513
YANDEX_MUSIC_TOKEN=ваш_токен_яндекс_музыки
